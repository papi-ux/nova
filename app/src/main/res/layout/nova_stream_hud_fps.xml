<?xml version="1.0" encoding="utf-8"?>
<!-- Nova Performance HUD — FPS-only mode (tiny pill) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/nova_hud_bg"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp"
    android:gravity="center_vertical"
    android:alpha="0.90">

    <!-- Status dot -->
    <View
        android:id="@+id/hud_status_dot"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:background="@drawable/nova_dot_green" />

    <!-- FPS number -->
    <TextView
        android:id="@+id/hud_fps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="60"
        android:textSize="13sp"
        android:textColor="#FF4ade80"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:layout_marginStart="4dp"
        android:includeFontPadding="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="fps"
        android:textSize="8sp"
        android:textColor="#66687b81"
        android:layout_marginStart="2dp"
        android:layout_marginBottom="1dp"
        android:layout_gravity="bottom" />

</LinearLayout>
