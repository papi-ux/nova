<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nova_sheet_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/nova_drag_handle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/quick_menu_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Quick Menu"
                    android:textColor="@color/nova_ice"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/quick_menu_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Stream controls, tuning, and session actions"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/quick_menu_session_mode"
                    style="@style/NovaQuickMenuState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Checking stream mode" />

                <TextView
                    android:id="@+id/quick_menu_health_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:maxLines="2"
                    android:text="Checking session health"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="10sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_disconnect"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Disconnect"
                android:textAllCaps="false"
                android:textColor="@color/nova_text_secondary"
                android:textSize="12sp"
                app:cornerRadius="10dp"
                app:strokeColor="@color/nova_divider" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_quit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="End"
                android:textAllCaps="false"
                android:textColor="@color/nova_error"
                android:textSize="12sp"
                app:cornerRadius="10dp"
                app:strokeColor="@color/nova_error" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/quick_keys_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:useDefaultMargins="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/qk_esc"
                style="@style/NovaQuickKey"
                android:layout_columnWeight="1"
                android:text="ESC" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/qk_alt_enter"
                style="@style/NovaQuickKey"
                android:layout_columnWeight="1"
                android:text="Alt + Enter" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/qk_alt_f4"
                style="@style/NovaQuickKey"
                android:layout_columnWeight="1"
                android:text="Alt + F4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/qk_f11"
                style="@style/NovaQuickKey"
                android:layout_columnWeight="1"
                android:text="F11" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/qk_super"
                style="@style/NovaQuickKey"
                android:layout_columnWeight="1"
                android:text="Meta" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/qk_ctrl_v"
                style="@style/NovaQuickKey"
                android:layout_columnWeight="1"
                android:text="Ctrl + V" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/nova_card_bg"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Stream Tuning"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/action_stability_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="52dp"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stability Mode"
                            android:textColor="@color/nova_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/stability_mode_caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Safer live fallback"
                            android:textColor="@color/nova_text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/stability_mode_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Ready" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toggle_adaptive_bitrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="52dp"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Adaptive Bitrate"
                            android:textColor="@color/nova_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/adaptive_bitrate_caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="live network response"
                            android:textColor="@color/nova_text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/adaptive_bitrate_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Off" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toggle_ai_optimizer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Optimizer"
                            android:textColor="@color/nova_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/ai_optimizer_caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="next launch"
                            android:textColor="@color/nova_text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/ai_optimizer_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Off" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toggle_mangohud"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MangoHud"
                            android:textColor="@color/nova_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/mangohud_caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/nova_mangohud_quick_menu_caption_default"
                            android:textColor="@color/nova_text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/mangohud_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Queued" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/nova_card_bg"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Overlays"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/toggle_hud"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nova HUD"
                        android:textColor="@color/nova_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/hud_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Off" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toggle_perf_stats"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Perf Stats"
                        android:textColor="@color/nova_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/perf_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Off" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/nova_card_bg"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Controls"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/toggle_mouse_mode"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mouse"
                        android:textColor="@color/nova_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/mouse_mode_label"
                        style="@style/NovaQuickMenuState"
                        android:text="Direct" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toggle_osc"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Controller"
                        android:textColor="@color/nova_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/osc_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Off" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toggle_keyboard"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Keyboard"
                        android:textColor="@color/nova_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/keyboard_state"
                        style="@style/NovaQuickMenuState"
                        android:text="Hidden" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/nova_card_bg"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Session"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/action_paste_clipboard"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="Paste Clipboard"
                    android:textColor="@color/nova_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/action_rotate_screen"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="Rotate Screen"
                    android:textColor="@color/nova_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/action_more_keys"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="Special Keys…"
                    android:textColor="@color/nova_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
