<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <!-- Animated space particle background (dense: nebulae + shooting stars) -->
    <com.papi.nova.ui.SpaceParticleView
        android:id="@+id/space_particles_dense"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/nova_library_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/nova_spacing_lg"
            android:paddingTop="@dimen/nova_spacing_sm"
            android:paddingEnd="@dimen/nova_spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nova_library_back"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:text="@string/pcview_mode_servers"
                    android:textAllCaps="false"
                    android:textColor="@color/nova_text_primary"
                    app:backgroundTint="@color/nova_badge_bg"
                    app:cornerRadius="14dp"
                    app:elevation="0dp"
                    app:icon="@drawable/ic_close"
                    app:iconPadding="8dp"
                    app:iconTint="@color/nova_text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/nova_spacing_md"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:text="@string/nova_library_browse_label"
                    android:textAllCaps="true"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="@dimen/nova_text_badge" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nova_library_refresh"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:text="@string/nova_refresh"
                    android:textAllCaps="false"
                    android:textColor="@color/nova_text_primary"
                    app:backgroundTint="@color/nova_badge_bg"
                    app:cornerRadius="14dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/nova_library_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/nova_spacing_xs"
                android:text="@string/nova_library_title"
                android:textColor="@color/nova_ice"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/nova_library_context"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/nova_library_server_context_fallback"
                android:textColor="@color/nova_text_muted"
                android:textSize="@dimen/nova_text_label"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/nova_library_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/nova_library_summary_placeholder"
                android:textColor="@color/nova_text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/nova_search"
                android:layout_width="match_parent"
                android:layout_height="@dimen/nova_search_height"
                android:layout_marginTop="@dimen/nova_spacing_xs"
                android:background="@drawable/nova_search_bg"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:drawableTint="@color/nova_text_muted"
                android:hint="@string/nova_library_search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:singleLine="true"
                android:textColor="@color/nova_text_primary"
                android:textColorHint="@color/nova_text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/nova_spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nova_library_filter_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.03"
                    android:text="@string/nova_library_browse_label"
                    android:textColor="@color/nova_text_primary"
                    android:textSize="@dimen/nova_text_label" />

                <TextView
                    android:id="@+id/nova_library_results"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/nova_library_results_format"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="@dimen/nova_text_caption" />
            </LinearLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/nova_spacing_md"
            android:paddingTop="@dimen/nova_spacing_xs"
            android:paddingEnd="@dimen/nova_spacing_md"
            android:paddingBottom="@dimen/nova_spacing_xs"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/nova_filter_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filter_all"
                    style="@style/NovaFilterChip"
                    android:background="@drawable/nova_chip_selected"
                    android:text="@string/nova_library_filter_all" />

                <TextView
                    android:id="@+id/filter_recent"
                    style="@style/NovaFilterChip"
                    android:text="@string/nova_library_filter_recent" />

                <TextView
                    android:id="@+id/filter_steam"
                    style="@style/NovaFilterChip"
                    android:text="@string/nova_library_filter_steam" />

                <TextView
                    android:id="@+id/filter_action"
                    style="@style/NovaFilterChip"
                    android:text="@string/nova_library_filter_action" />

                <TextView
                    android:id="@+id/filter_cinematic"
                    style="@style/NovaFilterChip"
                    android:text="@string/nova_library_filter_cinematic" />
            </LinearLayout>
        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <include
                android:id="@+id/nova_shimmer_container"
                layout="@layout/nova_shimmer_game_grid" />

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/nova_swipe_refresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/nova_game_grid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingStart="6dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="@dimen/nova_spacing_huge" />

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <LinearLayout
                android:id="@+id/nova_empty_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:alpha="0.35"
                    android:src="@drawable/ic_nova_star_foreground" />

                <TextView
                    android:id="@+id/nova_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/nova_spacing_md"
                    android:text="@string/nova_library_empty_title_default"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="@dimen/nova_text_title" />

                <TextView
                    android:id="@+id/nova_empty_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/nova_spacing_xs"
                    android:text="@string/nova_library_empty_hint_default"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="@dimen/nova_text_body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nova_empty_retry"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/nova_spacing_lg"
                    android:text="@string/nova_retry"
                    android:textColor="@color/nova_accent"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/nova_accent" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
