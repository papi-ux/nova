<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

<!-- Animated space particle background (dense: nebulae + shooting stars) -->
<com.papi.nova.ui.SpaceParticleView
    android:id="@+id/space_particles_dense"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/nova_library_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nova_library_title"
            android:textSize="26sp"
            android:textColor="@color/nova_ice"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />

        <TextView
            android:id="@+id/nova_library_context"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/nova_library_server_context_fallback"
            android:textColor="@color/nova_text_muted"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <EditText
            android:id="@+id/nova_search"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="@string/nova_library_search_hint"
            android:textColorHint="@color/nova_text_muted"
            android:textColor="@color/nova_text_primary"
            android:background="@drawable/nova_search_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawableTint="@color/nova_text_muted"
            android:drawablePadding="12dp" />
    </LinearLayout>

    <!-- Category filter tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/nova_filter_tabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filter_all"
                style="@style/NovaFilterChip"
                android:text="All"
                android:background="@drawable/nova_chip_selected" />

            <TextView
                android:id="@+id/filter_recent"
                style="@style/NovaFilterChip"
                android:text="Recent" />

            <TextView
                android:id="@+id/filter_steam"
                style="@style/NovaFilterChip"
                android:text="Steam" />

            <TextView
                android:id="@+id/filter_action"
                style="@style/NovaFilterChip"
                android:text="Action" />

            <TextView
                android:id="@+id/filter_cinematic"
                style="@style/NovaFilterChip"
                android:text="Cinematic" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Content Area (Grid + Empty State) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/nova_swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Game grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/nova_game_grid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/nova_empty_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/nova_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nova_library_empty_title_default"
                android:textColor="@color/nova_text_muted"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/nova_empty_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nova_library_empty_hint_default"
                android:textColor="@color/nova_text_muted"
                android:textSize="13sp"
                android:paddingTop="8dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
</FrameLayout>
