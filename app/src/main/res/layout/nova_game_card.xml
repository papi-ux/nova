<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/nova_spacing_sm"
    app:cardCornerRadius="@dimen/nova_card_corner_radius"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/nova_bg_card"
    android:foreground="@drawable/nova_ripple_accent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cover art -->
        <ImageView
            android:id="@+id/nova_cover_art"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nova_game_card_cover_height"
            android:scaleType="centerCrop"
            android:background="@color/nova_deep"
            android:transitionName="game_cover_art"
            android:contentDescription="@string/nova_a11y_game_cover" />

        <!-- Game info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/nova_spacing_md">

            <TextView
                android:id="@+id/nova_game_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/nova_ice"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Source + Category badges row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="6dp">

                <!-- Source badge -->
                <TextView
                    android:id="@+id/nova_source_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/nova_text_muted"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/nova_badge_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:visibility="gone" />

                <!-- Category badge -->
                <TextView
                    android:id="@+id/nova_category_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/nova_text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/nova_badge_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Genre chips row -->
            <LinearLayout
                android:id="@+id/nova_genre_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
