<?xml version="1.0" encoding="utf-8"?>
<!-- Nova server card — full-width horizontal with status -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/nova_spacing_xs">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/nova_card_bg"
        android:padding="@dimen/nova_spacing_md"
        android:foreground="@drawable/nova_ripple_accent">

        <!-- Server icon -->
        <FrameLayout
            android:layout_width="@dimen/nova_icon_server_container"
            android:layout_height="@dimen/nova_icon_server_container"
            android:gravity="center">

            <RelativeLayout
                android:id="@+id/grid_image_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <ImageView
                    android:id="@+id/grid_image"
                    android:layout_width="@dimen/nova_icon_server"
                    android:layout_height="@dimen/nova_icon_server"
                    android:layout_centerInParent="true"
                    android:contentDescription="@string/nova_a11y_server_icon" />

                <ImageView
                    android:id="@+id/grid_overlay"
                    android:layout_width="@dimen/nova_icon_overlay"
                    android:layout_height="@dimen/nova_icon_overlay"
                    android:layout_centerInParent="true"
                    android:importantForAccessibility="no" />

                <ProgressBar
                    android:id="@+id/grid_spinner"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_centerInParent="true"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/nova_accent" />
            </RelativeLayout>
        </FrameLayout>

        <!-- Server info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/nova_spacing_lg">

            <TextView
                android:id="@+id/grid_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/nova_text_body"
                android:textColor="@color/nova_ice"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Status row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="@dimen/nova_icon_status_dot"
                    android:layout_height="@dimen/nova_icon_status_dot"
                    android:background="@drawable/nova_status_connecting"
                    android:contentDescription="@string/nova_a11y_server_status" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/nova_spacing_sm"
                    android:textSize="@dimen/nova_text_label"
                    android:textColor="@color/nova_text_muted"
                    android:fontFamily="sans-serif"
                    android:text="Connecting..." />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/primary_action_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/nova_spacing_md"
            android:background="@drawable/nova_badge_bg"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="Open Apps"
            android:textColor="@color/nova_text_primary"
            android:textSize="12sp" />

    </LinearLayout>
</FrameLayout>
