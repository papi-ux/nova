<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".AppView">

    <!-- Space particles -->
    <com.papi.nova.ui.SpaceParticleView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/appListHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/appListText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textColor="@color/nova_ice"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Games"
                android:textSize="11sp"
                android:textColor="@color/nova_text_muted"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:paddingTop="4dp" />

        </LinearLayout>

        <!-- Search bar -->
        <EditText
            android:id="@+id/app_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            android:hint="Search games\u2026"
            android:textColorHint="@color/nova_text_muted"
            android:textColor="@color/nova_text_primary"
            android:textSize="14sp"
            android:background="@drawable/nova_search_bg"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:visibility="gone" />

        <!-- Recently played hero card -->
        <LinearLayout
            android:id="@+id/recently_played_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="108dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/nova_card_bg"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:focusable="true"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="74dp"
                android:layout_height="96dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/nova_deep">

                <ImageView
                    android:id="@+id/recently_played_art"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/recently_played_kicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/applist_hero_continue"
                    android:textSize="10sp"
                    android:textColor="@color/nova_accent"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/recently_played_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/nova_ice"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:paddingTop="3dp" />

                <TextView
                    android:id="@+id/recently_played_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/applist_hero_summary_continue"
                    android:textSize="13sp"
                    android:textColor="@color/nova_text_secondary"
                    android:fontFamily="sans-serif"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:paddingTop="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/recently_played_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:gravity="center"
                android:text="@string/pcview_card_action_resume"
                android:textSize="12sp"
                android:textColor="@color/nova_ice"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/nova_featured_action_bg"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp" />
        </LinearLayout>

        <!-- App grid -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/appSwipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/appFragmentContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- Profiles FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/profilesButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="24dp"
        android:contentDescription="@string/profile_manager_choose_profile"
        app:icon="@drawable/ic_profiles"
        app:backgroundTint="@color/nova_accent"
        app:iconTint="@color/nova_ice" />

</FrameLayout>
